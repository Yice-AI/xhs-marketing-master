# Public example configuration.
# Copy this file to .env and fill in your own provider keys and endpoints.

OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.example.com/v1
ANTHROPIC_BACKUP_API_KEY=
TUZI_API_KEY=

IMAGE_GEN_API_KEY=
IMAGE_GEN_BASE_URL=https://api.example.com/v1
IMAGE_GEN_BACKUP_API_KEY=
IMAGE_GEN_MODEL=your-image-model
IMAGE_JOB_MAX_CONCURRENCY=2

TEXT_GEN_BASE_URL=https://api.example.com/v1
TEXT_GEN_MODEL=your-text-model
INTERVIEW_MODEL=your-text-model
PROMPT_GEN_MODEL=your-text-model

LOG_LEVEL=INFO
JWT_SECRET_KEY=change-this-secret
JWT_EXPIRE_DAYS=7
DATABASE_URL=sqlite:///./xhs_marketing.db
TEXT_GENERATION_CANDIDATE_JUDGE_ENABLED=false
